# Polyglot Cup — environment variables
# The pipelines use only these two LLM keys:
#   polyglot.pipe        -> ROCKETRIDE_ANTHROPIC_KEY  (llm_anthropic)
#   polyglot-openai.pipe -> ROCKETRIDE_OPENAI_KEY     (llm_openai)
# Copy to .env (gitignored) and fill in. Never commit real keys.
# Local IDE engine mode needs no cloud URI/API key.

ROCKETRIDE_OPENAI_KEY=
ROCKETRIDE_ANTHROPIC_KEY=
